# ROOMIE localhost
APP_URL=http://localhost:3000

# Lascia vuoto per Clerk keyless/dev mode.
# Inserisci chiavi reali pk_test_/sk_test_ per login utenti veri e Google locale.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Opzionale: forza CDN Clerk se l'auto URL non risolve correttamente.
NEXT_PUBLIC_CLERK_JS_URL=https://cdn.jsdelivr.net/npm/@clerk/clerk-js@6/dist/clerk.browser.js
