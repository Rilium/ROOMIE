# ─── DATABASE ────────────────────────────────────────
# Neon PostgreSQL — obbligatorio in produzione
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── STRIPE ──────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── GOOGLE OAUTH ────────────────────────────────────
GOOGLE_CLIENT_ID=....apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# ─── AUTH SESSION ────────────────────────────────────
# Segreto HMAC per cookie firmati — cambia in produzione!
SESSION_SECRET=roomie-local-dev-secret-change-me

# ─── ADMIN BOOTSTRAP ─────────────────────────────────
# Imposta queste var per creare/aggiornare l'account admin all'avvio
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=cambia-questa-password
# ADMIN_NAME=ROOMIE Admin

# ─── APP ─────────────────────────────────────────────
# URL base app (necessario per OAuth redirect URI)
APP_URL=https://roomie.rilio.it

# NODE_ENV=production
