# ─── DATABASE ────────────────────────────────────────
# Neon PostgreSQL — obbligatorio in produzione
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── STRIPE ──────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── GOOGLE OAUTH ────────────────────────────────────
GOOGLE_CLIENT_ID=....apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# ─── CLERK AUTH ──────────────────────────────────────
# Locale:
# - lascia vuoto per usare Clerk keyless/dev mode
# - usa chiavi reali pk_test_/sk_test_ se vuoi testare utenti/OAuth della stessa istanza Clerk
# Produzione:
# - obbligatorio: NON usare placeholder tipo pk_test_YOUR_KEY
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ─── AUTH SESSION ────────────────────────────────────
# Segreto HMAC per cookie firmati — cambia in produzione!
SESSION_SECRET=roomie-local-dev-secret-change-me

# ─── ADMIN BOOTSTRAP ─────────────────────────────────
# Imposta queste var per creare/aggiornare l'account admin all'avvio
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=cambia-questa-password
# ADMIN_NAME=ROOMIE Admin

# ─── APP ─────────────────────────────────────────────
# URL base app (necessario per OAuth redirect URI)
APP_URL=https://roomie.rilio.it

# NODE_ENV=production
